{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svg-animator.invalid/schemas/runtime-bundle-v1.schema.json",
  "title": "SVG Animator RuntimeBundleV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "generator", "requiredCapabilities", "artwork", "animation"],
  "properties": {
    "kind": { "const": "svg-animator/runtime-bundle" },
    "formatVersion": { "const": 1 },
    "generator": {
      "type": "object", "additionalProperties": false, "required": ["name", "version"],
      "properties": { "name": { "const": "SVG Animator" }, "version": { "type": "string" } }
    },
    "requiredCapabilities": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/capability" } },
    "artwork": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "signature", "width", "height", "viewBox", "targets"],
      "properties": {
        "id": { "type": "string" }, "signature": { "type": "string", "pattern": "^fnv1a32-[0-9a-f]{8}$" },
        "width": { "type": "number" }, "height": { "type": "number" },
        "viewBox": { "type": "array", "prefixItems": [{"type":"number"},{"type":"number"},{"type":"number"},{"type":"number"}], "items": false },
        "targets": { "type": "array", "items": { "$ref": "#/$defs/target" } }
      }
    },
    "animation": {
      "type": "object", "additionalProperties": false,
      "required": ["duration", "loop", "markers", "variables", "targets", "properties", "tracks"],
      "properties": {
        "duration": { "type": "number", "minimum": 0 }, "loop": { "type": "boolean" },
        "markers": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["id", "time", "name"], "properties": { "id": {"type":"string"}, "time": {"type":"number"}, "name": {"type":"string"} } } },
        "variables": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["name", "value"], "properties": { "name": {"type":"string"}, "value": { "type": ["number", "string", "boolean"] } } } },
        "targets": { "type": "array", "items": {"type":"string"} }, "properties": { "type": "array", "items": {"type":"string"} },
        "tracks": { "type": "array", "items": { "oneOf": [{"$ref":"#/$defs/numericTrack"},{"$ref":"#/$defs/colorTrack"},{"$ref":"#/$defs/discreteTrack"}] } }
      }
    }
  },
  "$defs": {
    "capability": { "enum": ["tracks.numeric-v1","tracks.color-v1","tracks.discrete-v1","render.transforms-v1","render.geometry-v1","render.paint-v1","render.gradient-v1","render.path-v1","render.clipping-v1","render.motion-path-v1"] },
    "point": { "type":"object", "additionalProperties":false, "required":["id","x","y"], "properties":{"id":{"type":"string"},"x":{"type":"number"},"y":{"type":"number"},"cornerRadius":{"type":"number","minimum":0}} },
    "line": { "type":"object", "additionalProperties":false, "required":["id","type","points"], "properties":{"id":{"type":"string"},"type":{"enum":["line","bezier"]},"points":{"type":"array","minItems":2,"maxItems":2,"items":{"$ref":"#/$defs/point"}},"controlStart":{"$ref":"#/$defs/point"},"controlEnd":{"$ref":"#/$defs/point"}} },
    "paint": { "oneOf": [
      {"type":"null"},
      {"type":"object","additionalProperties":false,"required":["kind","color","opacity"],"properties":{"kind":{"const":"solid"},"color":{"type":"string"},"opacity":{"type":"number","minimum":0,"maximum":1}}},
      {"type":"object","required":["kind","id","gradientType","units","spreadMethod","transform","coordinates","stops"],"properties":{"kind":{"const":"gradient"},"id":{"type":"string"},"gradientType":{"enum":["linear-gradient","radial-gradient"]},"units":{"enum":["objectBoundingBox","userSpaceOnUse"]},"spreadMethod":{"enum":["pad","reflect","repeat"]},"transform":{"type":"array","minItems":6,"maxItems":6,"items":{"type":"number"}},"coordinates":{"type":"object","additionalProperties":{"type":"number"}},"stops":{"type":"array","items":{"type":"object","required":["id","offset","color","opacity"],"properties":{"id":{"type":"string"},"offset":{"type":"number"},"color":{"type":"string"},"opacity":{"type":"number"}}}}}}
    ]},
    "target": {
      "type":"object", "required":["id","parentId","type","visible","opacity","transform","motion","geometry","paints"],
      "properties": {
        "id":{"type":"string"},"parentId":{"type":["string","null"]},"type":{"enum":["group","path","rectangle","ellipse","text"]},"visible":{"type":"boolean"},"opacity":{"type":"number"},
        "transform":{"type":"object","additionalProperties":false,"required":["translateX","translateY","scaleX","scaleY","rotation","originX","originY","autoOrigin"],"properties":{"translateX":{"type":"number"},"translateY":{"type":"number"},"scaleX":{"type":"number"},"scaleY":{"type":"number"},"rotation":{"type":"number"},"originX":{"type":"number"},"originY":{"type":"number"},"autoOrigin":{"type":"boolean"}}},
        "motion":{"type":"object","required":["pathId","progress","offsetX","offsetY","rotateToPath","offsetAngle"]},
        "geometry":{"type":"object","required":["x","y","width","height"],"additionalProperties":{"type":"number"}},
        "paints":{"type":"object","properties":{"fill":{"$ref":"#/$defs/paint"},"stroke":{"$ref":"#/$defs/paint"},"color":{"$ref":"#/$defs/paint"}}},
        "path":{"type":"object","required":["contours","fillRule","drawProgress","rounded"],"properties":{"contours":{"type":"array","items":{"type":"object","required":["id","closed","lines"],"properties":{"id":{"type":"string"},"closed":{"type":"boolean"},"lines":{"type":"array","items":{"$ref":"#/$defs/line"}}}}},"fillRule":{"enum":["nonzero","evenodd"]},"drawProgress":{"type":"number"},"rounded":{"type":"boolean"}}},
        "stroke":{"type":"object","required":["width","alignment","dasharray","dashoffset"],"properties":{"width":{"type":"number"},"alignment":{"enum":["inside","center","outside"]},"dasharray":{"type":"array","items":{"type":"number"}},"dashoffset":{"type":"number"}}},
        "clipping":{"type":"object","required":["clipElementId","clipPathId"],"properties":{"clipElementId":{"type":"string"},"clipPathId":{"type":"string"}}}
      }
    },
    "trackBase": { "type":"object", "required":["kind","target","property","times","values"], "properties":{"target":{"type":"integer","minimum":0},"property":{"type":"integer","minimum":0},"times":{"type":"array","items":{"type":"number"}}} },
    "numericTrack": { "allOf":[{"$ref":"#/$defs/trackBase"},{"type":"object","properties":{"kind":{"const":"number"},"values":{"type":"array","items":{"type":"number"}},"segmentModes":{"type":"array","items":{"enum":["linear","hold","ease-in","ease-out","ease-in-out","temporal"]}},"temporalCoefficients":{"type":"array","items":{"type":"number"}}},"required":["segmentModes","temporalCoefficients"]}] },
    "colorTrack": { "allOf":[{"$ref":"#/$defs/trackBase"},{"type":"object","properties":{"kind":{"const":"color"},"values":{"type":"array","items":{"type":"integer"}},"segmentModes":{"type":"array"},"interpolationSpaces":{"type":"array","items":{"enum":["rgb","hsl"]}}},"required":["segmentModes","interpolationSpaces"]}] },
    "discreteTrack": { "allOf":[{"$ref":"#/$defs/trackBase"},{"type":"object","properties":{"kind":{"enum":["boolean","string"]},"values":{"type":"array","items":{"type":["boolean","string"]}}}}] }
  }
}
